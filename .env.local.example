# Supabase — copia questo file in .env.local e inserisci i valori dal tuo progetto Supabase.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Organization default (Sprint 1A) — UUID dalla migration organizations seed
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001

# Sprint 3 — utente per smoke test con RLS (creato da npm run bootstrap:sprint3)
# TEST_USER_EMAIL=yagiu-os-smoke-test@yagiutravel.com
# TEST_USER_PASSWORD=YagiuSmokeTest_2026!

# Sprint 3 — bootstrap automatico (richiesto)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # obbligatoria per creare l'utente test (Admin API)

# OpenAI — provider LLM per AI Assistant (server-side)
# OPENAI_API_KEY=sk-...
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
